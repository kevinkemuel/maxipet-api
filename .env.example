# Example .env file for MaxiPet API
# Copy this to .env and fill in your values

# Supabase ERP (mvyshricuovdufooldzz.supabase.co — schema maxipet)
SUPABASE_URL=your_erp_supabase_url_here
SUPABASE_KEY=your_erp_supabase_anon_key_here

# Supabase Catálogo (db.maxipetonline.com — schema public)
SUPABASE_CATALOG_URL=https://db.maxipetonline.com
SUPABASE_CATALOG_KEY=your_catalog_supabase_anon_key_here

# API Security
API_KEY_TOKEN=your_api_key_here
SECRET_KEY=your-secret-key-for-jwt-change-in-production

# Database (if using direct PostgreSQL connection)
DATABASE_URL=postgresql://user:password@host:port/database

# API Configuration
API_VERSION=v1
API_TITLE=MaxiPet API
API_DESCRIPTION=API para gestión de productos y webhooks de MaxiPet

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Webhooks
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=10

# Inventory
LOW_STOCK_THRESHOLD=10

# Logging
LOG_LEVEL=INFO
